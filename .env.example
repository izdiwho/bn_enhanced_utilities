# Copy to .env and fill in your values, then run: docker compose up

# ── Access PIN (optional) ─────────────────────────────────────────────────────
# Set a PIN to protect the dashboard. Leave blank for no PIN.
APP_PIN=

# ── Required: USMS credentials ────────────────────────────────────────────────
# Your IC number (with or without dashes — both formats accepted)
USMS_IC=
# Your USMS SmartMeter password
USMS_PASSWORD=

# ── AI Features (optional) ────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai
# Leave blank to disable AI appliance estimator
OPENROUTER_API_KEY=
# Override the model used for AI estimation (default: qwen/qwen3-235b-a22b-2507)
OPENROUTER_MODEL=qwen/qwen3-235b-a22b-2507

# ── Advanced (usually no need to change) ──────────────────────────────────────
# Override the USMS base URL (useful for testing against a mock server)
USMS_BASE_URL=https://www.usms.com.bn
