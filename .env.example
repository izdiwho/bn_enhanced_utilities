# Copy to .env and fill in your values, then run: docker compose up

# ── Access PIN (optional) ─────────────────────────────────────────────────────
# Set a PIN to protect the dashboard. Leave blank for no PIN.
APP_PIN=

# ── Required: USMS credentials ────────────────────────────────────────────────
# Your IC number (with or without dashes — both formats accepted)
USMS_IC=
# Your USMS SmartMeter password
USMS_PASSWORD=

# ── AI Features (optional) ────────────────────────────────────────────────────
# Works with any OpenAI-compatible API: OpenRouter, Ollama, Together AI, Groq, etc.
# Leave AI_API_KEY blank to disable AI features entirely.
#
# OpenRouter (default, free tier available):
#   AI_API_KEY=sk-or-v1-...
#   AI_API_URL=https://openrouter.ai/api/v1
#   AI_MODEL=qwen/qwen3-235b-a22b-2507
#
# Ollama (local, no API key needed):
#   AI_API_KEY=ollama
#   AI_API_URL=http://host.docker.internal:11434/v1
#   AI_MODEL=llama3.1
#
# Together AI:
#   AI_API_KEY=...
#   AI_API_URL=https://api.together.xyz/v1
#   AI_MODEL=meta-llama/Llama-3-70b-chat-hf
#
# Groq:
#   AI_API_KEY=gsk_...
#   AI_API_URL=https://api.groq.com/openai/v1
#   AI_MODEL=llama-3.1-70b-versatile

AI_API_KEY=
AI_API_URL=https://openrouter.ai/api/v1
AI_MODEL=qwen/qwen3-235b-a22b-2507

# Legacy aliases (still work, new vars take priority):
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# ── Scheduled Scraper (Phase 1) ──────────────────────────────────────────────
# Cron expression for when to run the scraper (default: every hour at minute 0)
SCRAPE_INTERVAL_CRON=0 * * * *
# Run scraper on backend startup if last success > 1 hour ago
SCRAPE_ON_STARTUP=true
# How many months back to scrape consumption data
SCRAPE_CONSUMPTION_MONTHS=3
# How many days back to scrape topup transactions
SCRAPE_TOPUP_DAYS=365

# ── Advanced (usually no need to change) ──────────────────────────────────────
# Override the USMS base URL (useful for testing against a mock server)
USMS_BASE_URL=https://www.usms.com.bn
